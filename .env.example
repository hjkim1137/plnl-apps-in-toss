# ───────────────────────────────────────────────────────────────────────────
# 뺄래 낼래 (plnl-apps-in-toss) 환경변수
# 이 파일을 복사해 `.env.local` 로 만들고 값을 채우세요. (.env.local 은 git 무시)
# 미설정 시 dev 환경에선 mock 흐름으로 전 기능 검증 가능. prod 토스 앱에선 안내 노출.
# ───────────────────────────────────────────────────────────────────────────

# Supabase (미니앱 전용 인스턴스)
# Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 토스 미니앱 전면형(interstitial) 광고 — 5초
# 앱인토스 콘솔 > 인앱 광고 > 광고 그룹 ID (전면형)
# 사용처: 출석 무료소진 후 / 스트릭 마일스톤 포인트 수령 / 월간 결산·표창장 열람
VITE_AD_GROUP_ID_INTERSTITIAL=

# 토스 미니앱 보상형(rewarded) 광고 — 30초
# 앱인토스 콘솔 > 인앱 광고 > 광고 그룹 ID (보상형)
# 사용처: 스트릭 보호권 획득 (끝까지 시청 = userEarnedReward 시 지급)
VITE_AD_GROUP_ID_REWARDED=

# 토스 미니앱 배너형 광고 (선택) — 결과 화면 하단
# 앱인토스 콘솔 > 인앱 광고 > 배너 광고 그룹 ID
VITE_AD_GROUP_ID_BANNER=

# 토스 로그인 백엔드 (별도 Next.js 레포에 docs/backend/ 라우트 배포 후 채움)
# 예: https://plnl.vercel.app/api/aits
# 미설정 시 dev mock 세션으로 흐름 검증, prod 토스 앱에선 로그인 실패 안내.
VITE_AITS_API_BASE=
